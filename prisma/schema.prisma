generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  SUPER_ADMIN
  MANAGER
  MEMBER
}

enum ExpenseCategory {
  MEAL_BAZAR
  HOUSE_RENT
  UTILITIES
  INTERNET
  MAID_BILL
  OTHER
}

enum TransactionType {
  DEPOSIT
  DEDUCTION
  ADJUSTMENT
}

// --- MODELS ---

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  phone          String?      @unique
  passwordHash   String
  firstName      String
  lastName       String
  profilePicture String?
  currentBalance Decimal      @default(0) @db.Decimal(12, 2)
  isActive       Boolean      @default(true)
  managedHouse   House?       @relation("HouseManager")
  membership     HouseMember?

  paidExpenses    Expense[]      @relation("Payer")
  createdExpenses Expense[]      @relation("ExpenseCreator")
  mealLogs        MealLog[]      @relation("MealUser")
  deposits        Deposit[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  transactions    Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model House {
  id                 String  @id @default(cuid())
  name               String
  address            String?
  isMealSystemActive Boolean @default(true)
  currentMealRate    Decimal @default(0) @db.Decimal(10, 4)
  managerId          String  @unique
  manager            User    @relation("HouseManager", fields: [managerId], references: [id])

  members      HouseMember[]
  expenses     Expense[]
  mealLogs     MealLog[]
  deposits     Deposit[]
  auditLogs    AuditLog[]
  transactions Transaction[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  updatedById    String?
  userFixedCosts UserFixedCost[]

  @@map("houses")
}

model HouseMember {
  id      String @id @default(cuid())
  houseId String
  userId  String @unique

  role     RoleType  @default(MEMBER)
  isActive Boolean   @default(true)
  joinDate DateTime  @default(now())
  leftDate DateTime?

  totalMeals   Decimal @default(0) @db.Decimal(10, 1)
  totalDeposit Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @default(0) @db.Decimal(10, 2)

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdById   String?
  updatedById   String?
  userFixedCost UserFixedCost?

  @@map("house_members")
}

model UserFixedCost {
  id       String @id @default(cuid())
  memberId String @unique
  houseId  String

  roomRent       Decimal @default(0) @db.Decimal(12, 2)
  khalaBill      Decimal @default(0) @db.Decimal(12, 2)
  wifiBill       Decimal @default(0) @db.Decimal(12, 2)
  electricity    Decimal @default(0) @db.Decimal(12, 2)
  gasBill        Decimal @default(0) @db.Decimal(12, 2)
  waterBill      Decimal @default(0) @db.Decimal(12, 2)
  otherBill      Decimal @default(0) @db.Decimal(12, 2)
  totalFixedCost Decimal @default(0) @db.Decimal(12, 2)

  lastUpdated DateTime @updatedAt
  updatedById String?

  member HouseMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  house  House       @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@map("user_fixed_costs")
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(MEAL_BAZAR)
  expenseDate DateTime        @default(now())

  isBazar     Boolean @default(true)
  isFixedCost Boolean @default(false)
  houseId     String
  payerId     String // Who paid the money
  house       House   @relation(fields: [houseId], references: [id], onDelete: Cascade)
  payer       User    @relation("Payer", fields: [payerId], references: [id])

  // Audit Fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String // Who entered the record
  creator     User     @relation("ExpenseCreator", fields: [createdById], references: [id])
  updatedById String?

  @@index([houseId, expenseDate])
  @@map("expenses")
}

model MealLog {
  id      String   @id @default(cuid())
  houseId String
  userId  String
  date    DateTime @db.Date

  breakfast Decimal @default(0) @db.Decimal(3, 1)
  lunch     Decimal @default(0) @db.Decimal(3, 1)
  dinner    Decimal @default(0) @db.Decimal(3, 1)
  totalDay  Decimal @default(0) @db.Decimal(3, 1)

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation("MealUser", fields: [userId], references: [id], onDelete: Cascade)

  // Audit Fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  updatedById String?

  @@unique([houseId, userId, date])
  @@map("meal_logs")
}

model Deposit {
  id      String   @id @default(cuid())
  houseId String
  userId  String
  amount  Decimal  @db.Decimal(12, 2)
  date    DateTime @default(now())

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit Fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  updatedById String?

  @@map("deposits")
}

model Transaction {
  id          String          @id @default(cuid())
  houseId     String
  userId      String
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?

  house House @relation(fields: [houseId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("transactions")
}

model AuditLog {
  id        String   @id @default(cuid())
  houseId   String
  userId    String? // Action Performer
  action    String // e.g., CREATE, UPDATE, DELETE
  entity    String // e.g., Expense, MealLog
  entityId  String
  payload   Json? // Stores the data involved
  createdAt DateTime @default(now())

  house House @relation(fields: [houseId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
