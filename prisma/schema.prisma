// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  ADMIN
  MANAGER
  MEMBER
}

enum ExpenseCategory {
  MEAL
  BAZAR
  RENT
  UTILITIES
  EXTRA
  TRANSPORT
  OTHER
}

// --- MODELS ---

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  phone          String? @unique
  passwordHash   String
  firstName      String
  lastName       String
  profilePicture String?

  // Wallet for Bachelor balance tracking
  currentBalance Decimal @default(0) @db.Decimal(12, 2)
  isActive       Boolean @default(true)

  // Relations
  managedHouses House[]        @relation("HouseManager")
  memberships   HouseMember[]
  paidExpenses  Expense[]      @relation("PayerExpenses")
  mealLogs      MealLog[]
  deposits      Deposit[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model House {
  id      String  @id @default(cuid())
  name    String
  address String?

  // Bachelor Configuration
  isMealSystemActive Boolean @default(true)
  currentMealRate    Decimal @default(0) @db.Decimal(10, 4) // Higher precision for rates

  // Manager Relation
  managerId String
  manager   User   @relation("HouseManager", fields: [managerId], references: [id])

  // House Relations
  members  HouseMember[]
  expenses Expense[]
  mealLogs MealLog[]
  deposits Deposit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("houses")
}

model HouseMember {
  id        String    @id @default(cuid())
  houseId   String
  userId    String
  role      RoleType  @default(MEMBER)
  isActive  Boolean   @default(true)
  joinDate  DateTime  @default(now())
  leaveDate DateTime?

  // Real-time calculated stats for the dashboard
  totalMeals   Decimal @default(0) @db.Decimal(10, 1)
  totalDeposit Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @default(0) @db.Decimal(10, 2)

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([houseId, userId])
  @@index([userId])
  @@map("house_members")
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(BAZAR)
  expenseDate DateTime        @default(now())

  // Business Logic Flags
  isBazar     Boolean @default(true) // If true, used to calculate Meal Rate
  isFixedCost Boolean @default(false) // If true, split equally among members (e.g., Wifi)

  payerId String
  houseId String

  payer User  @relation("PayerExpenses", fields: [payerId], references: [id])
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([houseId, expenseDate])
  @@map("expenses")
}

model MealLog {
  id        String   @id @default(cuid())
  houseId   String
  userId    String
  date      DateTime @db.Date // Strictly stores YYYY-MM-DD
  breakfast Decimal  @default(0) @db.Decimal(3, 1)
  lunch     Decimal  @default(0) @db.Decimal(3, 1)
  dinner    Decimal  @default(0) @db.Decimal(3, 1)
  totalDay  Decimal  @default(0) @db.Decimal(3, 1)

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([houseId, userId, date])
  @@index([date])
  @@map("meal_logs")
}

model Deposit {
  id      String   @id @default(cuid())
  houseId String
  userId  String
  amount  Decimal  @db.Decimal(12, 2)
  date    DateTime @default(now())
  month   Int // 1 to 12
  year    Int // e.g., 2024

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([houseId, month, year])
  @@map("deposits")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
